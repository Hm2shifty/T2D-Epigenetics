# Python environment
venv/
.env
__pycache__/
*.py[cod]
.ipynb_checkpoints

# DATA - CRITICAL: Ignore ALL content in the data directory recursively
# This protects your 8GB RAM and your GitHub storage
data/**

# Exceptions: If you want to keep the folder structure in Git but not the data,
# we allow the .gitkeep files
!data/**/.gitkeep

# Notebooks and temporary files
.DS_Store

# Large log files
*.log